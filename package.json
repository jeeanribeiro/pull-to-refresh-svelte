{
	"name": "pull-to-refresh-svelte",
	"version": "1.0.0",
	"description": "Pull-to-refresh for Svelte 5 — faithful iOS and Material indicators, SSR-safe, touch and mouse",
	"license": "MIT",
	"author": "Jean Ribeiro <contact@jeanribeiro.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeeanribeiro/pull-to-refresh-svelte.git"
	},
	"homepage": "https://jeeanribeiro.github.io/pull-to-refresh-svelte/",
	"bugs": "https://github.com/jeeanribeiro/pull-to-refresh-svelte/issues",
	"keywords": [
		"svelte",
		"svelte5",
		"pull-to-refresh",
		"ptr",
		"mobile",
		"touch",
		"gesture",
		"ios",
		"material"
	],
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.29.3",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"dev": "vite dev --port 43130",
		"build": "vite build && pnpm run package",
		"preview": "vite preview --port 43132 --strictPort",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepare": "svelte-kit sync",
		"prepack": "svelte-package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "pnpm run test:unit && pnpm run test:e2e",
		"changeset": "changeset",
		"release": "pnpm run build && changeset publish"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.1",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.0",
		"@testing-library/svelte": "^5.2.8",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.21.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.9.0",
		"prettier-plugin-svelte": "^4.1.1",
		"publint": "^0.3.14",
		"qrcode": "^1.5.4",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.46.4",
		"vite": "^8.1.5",
		"vitest": "^4.1.0"
	}
}
